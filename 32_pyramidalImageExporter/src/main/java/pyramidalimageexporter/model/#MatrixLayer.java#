package pyramidalimageexporter.model;

import com.fasterxml.jackson.annotation.JsonAlias;
import java.util.ArrayList;
import java.util.List;
import pyramidalimageexporter.processing.uncles.ToUncleRelationship;

public final class MatrixLayer {
    private int frameId;
    private int rows;
    private int cols;
    private String sourceFolderName;
    private List<TileCoord> tiles = new ArrayList<>();

    public int getFrameId() {
        return frameId;
    }

    public void setFrameId(int frameId) {
        this.frameId = frameId;
    }

    public int getRows() {
        return rows;
    }

    public void setRows(int rows) {
        this.rows = rows;
    }

    public int getCols() {
        return cols;
    }

    public void setCols(int cols) {
        this.cols = cols;
    }

    public String getSourceFolderName() {
        return sourceFolderName;
    }

    public void setSourceFolderName(String sourceFolderName) {
        this.sourceFolderName = sourceFolderName;
    }

    public List<TileCoord> getTiles() {
        return tiles;
    }

    public void setTiles(List<TileCoord> tiles) {
        this.tiles = tiles == null ? new ArrayList<>() : new ArrayList<>(tiles);
    }
}
